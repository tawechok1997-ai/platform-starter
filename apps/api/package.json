{
  "name": "@platform/api",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "node ../../tools/audit-typescript-config-boundaries.mjs && node ../../tools/audit-refactor-regressions.mjs && prisma generate --schema ../../prisma/schema.prisma && nest build && node ../../tools/check-api-build-artifact.mjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:strict-next": "tsc -p tsconfig.strict-next.json",
    "start:prod": "node dist/main.js",
    "test": "jest",
    "test:db:finance": "jest src/modules/finance/finance-concurrency.db.spec.ts --runInBand",
    "test:db:promotions": "jest src/modules/promotions/promotion-settlement.db.spec.ts --runInBand",
    "test:db:phone-otp": "jest src/modules/auth/phone-otp.db.spec.ts --runInBand",
    "test:db:risk-watchlist": "jest src/modules/risk-alerts/risk-watchlist-concurrency.db.spec.ts --runInBand",
    "test:db:kyc": "jest src/modules/risk-alerts/kyc-concurrency.db.spec.ts --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1084.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.28",
    "@prisma/client": "6.19.3",
    "argon2": "0.44.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "ioredis": "5.11.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.23",
    "@nestjs/testing": "11.1.28",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.1",
    "@types/passport-jwt": "4.0.1",
    "jest": "30.4.2",
    "prisma": "6.19.3",
    "ts-jest": "29.4.11",
    "typescript": "5.7.3"
  }
}
