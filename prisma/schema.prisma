generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  CLOSED
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
  LOCKED
}

enum AdminDelegationStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum SessionType {
  MEMBER
  ADMIN
}

enum VerificationType {
  EMAIL
  PHONE
  PASSWORD_RESET
  TWO_FACTOR
}

enum SiteSettingGroup {
  WEBSITE
  BRANDING
  THEME
  SEO
  CONTACT
  MAINTENANCE
  SCRIPTS
  FEATURES
  LEGAL
}

enum SiteSettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  URL
  COLOR
  RICH_TEXT
}

enum WalletStatus {
  ACTIVE
  LOCKED
  CLOSED
}

enum WalletLedgerType {
  ADJUSTMENT
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  BONUS
  REVERSAL
}

enum WalletLedgerDirection {
  CREDIT
  DEBIT
}

enum TopUpRequestStatus {
  PENDING
  PENDING_SLIP_REVIEW
  SLIP_APPROVED
  PENDING_CREDIT
  CREDIT_CONFIRMED
  DUPLICATE
  COMPLETED
  APPROVED
  REJECTED
  CANCELLED
}

enum WithdrawalRequestStatus {
  PENDING
  PENDING_REVIEW
  APPROVED_FOR_PAYMENT
  PAYMENT_PROOF_UPLOADED
  PAYMENT_VERIFIED
  COMPLETED
  REJECTED
  CANCELLED
}

enum BankAccountStatus {
  ACTIVE
  DISABLED
  PENDING_REVIEW
  REJECTED
}

enum RiskAlertStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum RiskAlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskAlertType {
  DUPLICATE_DEPOSIT_SLIP
  REPEATED_DUPLICATE_DEPOSIT_SLIP
  REPEATED_TOPUPS
  RAPID_DEPOSIT_WITHDRAWAL
  HIGH_WITHDRAWAL
  BANK_CHANGE_WITHDRAWAL
  MULTIPLE_PENDING_TOPUPS
  WALLET_LEDGER_MISMATCH
}

enum GameProviderStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DEGRADED
}

enum GameProviderWalletMode {
  SEAMLESS
  TRANSFER
  HYBRID
}

enum GameProviderEndpointType {
  LAUNCH
  BALANCE
  TRANSFER_IN
  TRANSFER_OUT
  GAME_LIST
  BET_HISTORY
  WEBHOOK
  HEALTH_CHECK
}

enum GameProviderCredentialType {
  API_KEY
  SECRET_KEY
  MERCHANT_ID
  AGENT_ID
  WEBHOOK_SECRET
  TOKEN
}

enum GameStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  REMOVED
}

enum GameMediaType {
  COVER
  ICON
  THUMBNAIL
  BANNER
  LOGO
  FALLBACK
}

enum GameMediaStatus {
  PENDING
  READY
  BROKEN
  FALLBACK
}

enum GameSessionStatus {
  CREATED
  LAUNCHED
  ACTIVE
  ENDED
  FAILED
  EXPIRED
}

enum GameTransferType {
  TRANSFER_IN
  TRANSFER_OUT
  SYNC
  ROLLBACK
  ADJUSTMENT
}

enum GameTransferStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
  CANCELLED
}

enum ProviderWalletSnapshotStatus {
  MATCHED
  MISMATCH
  UNKNOWN
}

enum WebhookLogStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
  IGNORED
  RESOLVED
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  username                String                   @unique @db.VarChar(50)
  phone                   String?                  @unique @db.VarChar(30)
  email                   String?                  @unique @db.VarChar(255)
  passwordHash            String                   @map("password_hash")
  status                  UserStatus               @default(ACTIVE)
  phoneVerifiedAt         DateTime?                @map("phone_verified_at")
  emailVerifiedAt         DateTime?                @map("email_verified_at")
  lastLoginAt             DateTime?                @map("last_login_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  profile                 UserProfile?
  sessions                AuthSession[]
  loginHistory            LoginHistory[]
  notificationStates      NotificationState[]
  notificationPreference  NotificationPreference?
  wallet                  Wallet?
  walletLedgers           WalletLedger[]
  topUpRequests           TopUpRequest[]
  withdrawalRequests      WithdrawalRequest[]
  bankAccounts            MemberBankAccount[]
  gameSessions            GameSession[]
  gameTransfers           GameTransfer[]
  providerWalletSnapshots ProviderWalletSnapshot[]

  @@map("users")
}

model UserProfile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  displayName String?   @map("display_name") @db.VarChar(100)
  avatarUrl   String?   @map("avatar_url")
  birthday    DateTime?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model AdminUser {
  id               String      @id @default(uuid()) @db.Uuid
  username         String      @unique @db.VarChar(50)
  email            String      @unique @db.VarChar(255)
  passwordHash     String      @map("password_hash")
  status           AdminStatus @default(ACTIVE)
  twoFactorEnabled Boolean     @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?     @map("two_factor_secret")
  lastLoginAt      DateTime?   @map("last_login_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  roles                           AdminUserRole[]
  sessions                        AuthSession[]
  loginHistory                    LoginHistory[]
  auditLogs                       AdminAuditLog[]
  recoveryCodes                   AdminRecoveryCode[]
  walletLedgerEntries             WalletLedger[]
  reviewedTopUps                  TopUpRequest[]
  reviewedWithdrawals             WithdrawalRequest[]
  slipReviewedTopUps              TopUpRequest[]      @relation("TopUpSlipReviewer")
  creditConfirmedTopUps           TopUpRequest[]      @relation("TopUpCreditConfirmer")
  approvedForPaymentWithdrawals   WithdrawalRequest[] @relation("WithdrawalPaymentApprover")
  uploadedPaymentProofWithdrawals WithdrawalRequest[] @relation("WithdrawalProofUploader")
  verifiedPaymentWithdrawals      WithdrawalRequest[] @relation("WithdrawalPaymentVerifier")
  assignedRiskAlerts              RiskAlert[]         @relation("RiskAlertAssignee")
  riskAlertNotes                  RiskAlertNote[]
  delegationsGranted              AdminDelegation[]   @relation("DelegationGrantor")
  delegationsReceived             AdminDelegation[]   @relation("DelegationDelegate")

  @@map("admin_users")
}

model AdminDelegation {
  id               String                @id @default(uuid()) @db.Uuid
  grantorAdminId   String                @map("grantor_admin_id") @db.Uuid
  delegateAdminId  String                @map("delegate_admin_id") @db.Uuid
  permissionCodes  String[]              @map("permission_codes")
  status           AdminDelegationStatus @default(ACTIVE)
  reason           String?               @db.VarChar(500)
  expiresAt        DateTime              @map("expires_at")
  revokedAt        DateTime?             @map("revoked_at")
  revokedByAdminId String?               @map("revoked_by_admin_id") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  grantor          AdminUser             @relation("DelegationGrantor", fields: [grantorAdminId], references: [id], onDelete: Cascade)
  delegate         AdminUser             @relation("DelegationDelegate", fields: [delegateAdminId], references: [id], onDelete: Cascade)

  @@index([delegateAdminId, status, expiresAt])
  @@index([grantorAdminId, status])
  @@map("admin_delegations")
}

model AdminRecoveryCode {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @map("admin_user_id") @db.Uuid
  codeHash    String    @map("code_hash")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([usedAt])
  @@map("admin_recovery_codes")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(80)
  name        String           @db.VarChar(100)
  description String?
  level       Int              @default(100)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  adminUsers  AdminUserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(120)
  name        String           @db.VarChar(120)
  module      String           @db.VarChar(80)
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model AdminUserRole {
  adminUserId String    @map("admin_user_id") @db.Uuid
  roleId      String    @map("role_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminUserId, roleId])
  @@map("admin_user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuthSession {
  id               String      @id @default(uuid()) @db.Uuid
  type             SessionType
  userId           String?     @map("user_id") @db.Uuid
  adminUserId      String?     @map("admin_user_id") @db.Uuid
  refreshTokenHash String      @map("refresh_token_hash")
  ipAddress        String?     @map("ip_address") @db.VarChar(64)
  userAgent        String?     @map("user_agent")
  deviceId         String?     @map("device_id") @db.VarChar(120)
  expiresAt        DateTime    @map("expires_at")
  revokedAt        DateTime?   @map("revoked_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  user             User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser        AdminUser?  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminUserId])
  @@map("auth_sessions")
}

model LoginHistory {
  id          String      @id @default(uuid()) @db.Uuid
  type        SessionType
  userId      String?     @map("user_id") @db.Uuid
  adminUserId String?     @map("admin_user_id") @db.Uuid
  success     Boolean
  ipAddress   String?     @map("ip_address") @db.VarChar(64)
  userAgent   String?     @map("user_agent")
  reason      String?
  createdAt   DateTime    @default(now()) @map("created_at")
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  adminUser   AdminUser?  @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminUserId])
  @@map("login_history")
}

model VerificationToken {
  id        String           @id @default(uuid()) @db.Uuid
  type      VerificationType
  target    String           @db.VarChar(255)
  tokenHash String           @map("token_hash")
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now())

  @@index([target, type])
  @@map("verification_tokens")
}

model AdminAuditLog {
  id          String     @id @default(uuid()) @db.Uuid
  adminUserId String?    @map("admin_user_id") @db.Uuid
  action      String     @db.VarChar(120)
  module      String     @db.VarChar(80)
  targetId    String?    @map("target_id") @db.VarChar(120)
  oldData     Json?      @map("old_data")
  newData     Json?      @map("new_data")
  ipAddress   String?    @map("ip_address") @db.VarChar(64)
  userAgent   String?    @map("user_agent")
  createdAt   DateTime   @default(now()) @map("created_at")
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([module, action])
  @@map("admin_audit_logs")
}

model RiskAlert {
  id                String            @id @default(uuid()) @db.Uuid
  type              RiskAlertType
  severity          RiskAlertSeverity
  status            RiskAlertStatus   @default(OPEN)
  memberId          String?           @map("member_id") @db.Uuid
  refType           String?           @map("ref_type") @db.VarChar(80)
  refId             String?           @map("ref_id") @db.VarChar(120)
  title             String            @db.VarChar(180)
  description       String?
  metadata          Json?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  resolvedAt        DateTime?         @map("resolved_at")
  resolvedBy        String?           @map("resolved_by") @db.Uuid
  assignedToAdminId String?           @map("assigned_to_admin_id") @db.Uuid
  assignedAt        DateTime?         @map("assigned_at")
  assignedToAdmin   AdminUser?        @relation("RiskAlertAssignee", fields: [assignedToAdminId], references: [id], onDelete: SetNull)
  notes             RiskAlertNote[]

  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([memberId])
  @@index([refType, refId])
  @@index([assignedToAdminId, status])
  @@map("risk_alerts")
}

model RiskAlertNote {
  id          String    @id @default(uuid()) @db.Uuid
  riskAlertId String    @map("risk_alert_id") @db.Uuid
  adminUserId String    @map("admin_user_id") @db.Uuid
  note        String    @db.VarChar(2000)
  createdAt   DateTime  @default(now()) @map("created_at")
  riskAlert   RiskAlert @relation(fields: [riskAlertId], references: [id], onDelete: Cascade)
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([riskAlertId, createdAt])
  @@index([adminUserId, createdAt])
  @@map("risk_alert_notes")
}

model Wallet {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @unique @map("user_id") @db.Uuid
  currency      String         @default("THB") @db.VarChar(10)
  balance       Decimal        @default(0) @db.Decimal(18, 2)
  lockedBalance Decimal        @default(0) @map("locked_balance") @db.Decimal(18, 2)
  status        WalletStatus   @default(ACTIVE)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgers       WalletLedger[]

  @@index([status])
  @@map("wallets")
}

model WalletLedger {
  id               String                @id @default(uuid()) @db.Uuid
  walletId         String                @map("wallet_id") @db.Uuid
  userId           String                @map("user_id") @db.Uuid
  type             WalletLedgerType
  direction        WalletLedgerDirection
  amount           Decimal               @db.Decimal(18, 2)
  balanceBefore    Decimal               @map("balance_before") @db.Decimal(18, 2)
  balanceAfter     Decimal               @map("balance_after") @db.Decimal(18, 2)
  referenceType    String?               @map("reference_type") @db.VarChar(80)
  referenceId      String?               @map("reference_id") @db.VarChar(120)
  idempotencyKey   String?               @unique @map("idempotency_key") @db.VarChar(160)
  metadata         Json?
  createdByAdminId String?               @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at")

  wallet               Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdByAdmin       AdminUser?          @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)
  creditedTopUps       TopUpRequest[]      @relation("TopUpCreditLedger")
  completedWithdrawals WithdrawalRequest[] @relation("WithdrawalCompletionLedger")

  @@index([walletId, createdAt])
  @@index([userId, createdAt])
  @@index([type])
  @@index([referenceType, referenceId])
  @@map("wallet_ledgers")
}

model TopUpRequest {
  id                  String             @id @default(uuid()) @db.Uuid
  userId              String             @map("user_id") @db.Uuid
  amount              Decimal            @db.Decimal(18, 2)
  currency            String             @default("THB") @db.VarChar(10)
  status              TopUpRequestStatus @default(PENDING)
  method              String?            @db.VarChar(80)
  referenceCode       String?            @map("reference_code") @db.VarChar(120)
  idempotencyKey      String?            @unique @map("idempotency_key") @db.VarChar(160)
  note                String?
  adminNote           String?            @map("admin_note")
  reviewedBy          String?            @map("reviewed_by") @db.Uuid
  reviewedAt          DateTime?          @map("reviewed_at")
  claimedBy           String?            @map("claimed_by") @db.Uuid
  claimedAt           DateTime?          @map("claimed_at")
  slipUrl             String?            @map("slip_url")
  slipFileHash        String?            @map("slip_file_hash") @db.VarChar(128)
  slipPerceptualHash  String?            @map("slip_perceptual_hash") @db.VarChar(128)
  slipTransactionRef  String?            @map("slip_transaction_ref") @db.VarChar(160)
  slipDetectedAmount  Decimal?           @map("slip_detected_amount") @db.Decimal(18, 2)
  slipTransferredAt   DateTime?          @map("slip_transferred_at")
  duplicateOfId       String?            @map("duplicate_of_id") @db.Uuid
  duplicateReason     String?            @map("duplicate_reason") @db.VarChar(160)
  duplicateMatchScore Decimal?           @map("duplicate_match_score") @db.Decimal(8, 5)
  slipReviewedBy      String?            @map("slip_reviewed_by") @db.Uuid
  slipReviewedAt      DateTime?          @map("slip_reviewed_at")
  creditConfirmedBy   String?            @map("credit_confirmed_by") @db.Uuid
  creditConfirmedAt   DateTime?          @map("credit_confirmed_at")
  creditedLedgerId    String?            @map("credited_ledger_id") @db.Uuid
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer          AdminUser?     @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)
  slipReviewer      AdminUser?     @relation("TopUpSlipReviewer", fields: [slipReviewedBy], references: [id], onDelete: SetNull)
  creditConfirmer   AdminUser?     @relation("TopUpCreditConfirmer", fields: [creditConfirmedBy], references: [id], onDelete: SetNull)
  creditedLedger    WalletLedger?  @relation("TopUpCreditLedger", fields: [creditedLedgerId], references: [id], onDelete: SetNull)
  duplicateOf       TopUpRequest?  @relation("TopUpDuplicate", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicateRequests TopUpRequest[] @relation("TopUpDuplicate")

  @@index([userId, createdAt])
  @@index([status])
  @@index([reviewedBy])
  @@index([claimedBy])
  @@index([duplicateOfId])
  @@index([slipPerceptualHash])
  @@map("top_up_requests")
}

model WithdrawalRequest {
  id                    String                  @id @default(uuid()) @db.Uuid
  userId                String                  @map("user_id") @db.Uuid
  amount                Decimal                 @db.Decimal(18, 2)
  currency              String                  @default("THB") @db.VarChar(10)
  status                WithdrawalRequestStatus @default(PENDING)
  method                String?                 @db.VarChar(80)
  accountName           String?                 @map("account_name") @db.VarChar(160)
  accountNumber         String?                 @map("account_number") @db.VarChar(160)
  bankName              String?                 @map("bank_name") @db.VarChar(160)
  idempotencyKey        String?                 @unique @map("idempotency_key") @db.VarChar(160)
  note                  String?
  adminNote             String?                 @map("admin_note")
  reviewedBy            String?                 @map("reviewed_by") @db.Uuid
  reviewedAt            DateTime?               @map("reviewed_at")
  claimedBy             String?                 @map("claimed_by") @db.Uuid
  claimedAt             DateTime?               @map("claimed_at")
  paymentSlipUrl        String?                 @map("payment_slip_url")
  paymentSlipFileHash   String?                 @map("payment_slip_file_hash") @db.VarChar(128)
  paymentTransactionRef String?                 @map("payment_transaction_ref") @db.VarChar(160)
  approvedForPaymentBy  String?                 @map("approved_for_payment_by") @db.Uuid
  approvedForPaymentAt  DateTime?               @map("approved_for_payment_at")
  paymentUploadedBy     String?                 @map("payment_uploaded_by") @db.Uuid
  paymentUploadedAt     DateTime?               @map("payment_uploaded_at")
  paymentVerifiedBy     String?                 @map("payment_verified_by") @db.Uuid
  paymentVerifiedAt     DateTime?               @map("payment_verified_at")
  completedLedgerId     String?                 @map("completed_ledger_id") @db.Uuid
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer        AdminUser?    @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)
  paymentApprover AdminUser?    @relation("WithdrawalPaymentApprover", fields: [approvedForPaymentBy], references: [id], onDelete: SetNull)
  proofUploader   AdminUser?    @relation("WithdrawalProofUploader", fields: [paymentUploadedBy], references: [id], onDelete: SetNull)
  paymentVerifier AdminUser?    @relation("WithdrawalPaymentVerifier", fields: [paymentVerifiedBy], references: [id], onDelete: SetNull)
  completedLedger WalletLedger? @relation("WithdrawalCompletionLedger", fields: [completedLedgerId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@index([reviewedBy])
  @@index([claimedBy])
  @@map("withdrawal_requests")
}

model ReceivingBankAccount {
  id            String            @id @default(uuid()) @db.Uuid
  bankName      String            @map("bank_name") @db.VarChar(120)
  accountName   String            @map("account_name") @db.VarChar(160)
  accountNumber String            @map("account_number") @db.VarChar(160)
  promptPay     String?           @map("prompt_pay") @db.VarChar(160)
  qrImageUrl    String?           @map("qr_image_url")
  minAmount     Decimal?          @map("min_amount") @db.Decimal(18, 2)
  maxAmount     Decimal?          @map("max_amount") @db.Decimal(18, 2)
  status        BankAccountStatus @default(ACTIVE)
  sortOrder     Int               @default(100) @map("sort_order")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([status])
  @@map("receiving_bank_accounts")
}

model MemberBankAccount {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @unique @map("user_id") @db.Uuid
  bankName      String            @map("bank_name") @db.VarChar(120)
  accountName   String            @map("account_name") @db.VarChar(160)
  accountNumber String            @unique @map("account_number") @db.VarChar(160)
  isPrimary     Boolean           @default(false) @map("is_primary")
  status        BankAccountStatus @default(PENDING_REVIEW)
  adminNote     String?           @map("admin_note")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("member_bank_accounts")
}

model SiteSetting {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(160)
  valueJson   Json             @map("value_json")
  group       SiteSettingGroup
  type        SiteSettingType  @default(JSON)
  isPublic    Boolean          @default(false) @map("is_public")
  isSensitive Boolean          @default(false) @map("is_sensitive")
  updatedBy   String?          @map("updated_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([group])
  @@index([isPublic])
  @@map("site_settings")
}

model SiteSettingHistory {
  id           String   @id @default(uuid()) @db.Uuid
  settingKey   String   @map("setting_key") @db.VarChar(160)
  oldValueJson Json?    @map("old_value_json")
  newValueJson Json?    @map("new_value_json")
  changedBy    String?  @map("changed_by") @db.Uuid
  ipAddress    String?  @map("ip_address") @db.VarChar(64)
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([settingKey])
  @@index([changedBy])
  @@map("site_setting_histories")
}

model GameProvider {
  id              String                   @id @default(uuid()) @db.Uuid
  name            String                   @db.VarChar(120)
  code            String                   @unique @db.VarChar(80)
  logoUrl         String?                  @map("logo_url")
  status          GameProviderStatus       @default(INACTIVE)
  walletMode      GameProviderWalletMode   @default(TRANSFER) @map("wallet_mode")
  currency        String                   @default("THB") @db.VarChar(10)
  timezone        String                   @default("Asia/Bangkok") @db.VarChar(80)
  sortOrder       Int                      @default(100) @map("sort_order")
  metadata        Json?
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  endpoints       GameProviderEndpoint[]
  credentials     GameProviderCredential[]
  games           Game[]
  media           GameMedia[]
  sessions        GameSession[]
  transfers       GameTransfer[]
  walletSnapshots ProviderWalletSnapshot[]
  webhookLogs     WebhookLog[]

  @@index([status])
  @@index([walletMode])
  @@map("game_providers")
}

model GameProviderEndpoint {
  id         String                   @id @default(uuid()) @db.Uuid
  providerId String                   @map("provider_id") @db.Uuid
  type       GameProviderEndpointType
  url        String
  method     String                   @default("POST") @db.VarChar(12)
  timeoutMs  Int                      @default(10000) @map("timeout_ms")
  retryCount Int                      @default(2) @map("retry_count")
  isEnabled  Boolean                  @default(true) @map("is_enabled")
  createdAt  DateTime                 @default(now()) @map("created_at")
  updatedAt  DateTime                 @updatedAt @map("updated_at")
  provider   GameProvider             @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, type])
  @@index([providerId])
  @@index([type])
  @@map("game_provider_endpoints")
}

model GameProviderCredential {
  id             String                     @id @default(uuid()) @db.Uuid
  providerId     String                     @map("provider_id") @db.Uuid
  type           GameProviderCredentialType
  encryptedValue String                     @map("encrypted_value")
  maskedValue    String                     @map("masked_value") @db.VarChar(120)
  isEnabled      Boolean                    @default(true) @map("is_enabled")
  rotatedAt      DateTime?                  @map("rotated_at")
  lastUsedAt      DateTime?                  @map("last_used_at")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")
  provider       GameProvider               @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, type])
  @@index([providerId])
  @@index([type])
  @@map("game_provider_credentials")
}

model Game {
  id               String        @id @default(uuid()) @db.Uuid
  providerId       String        @map("provider_id") @db.Uuid
  providerGameCode String        @map("provider_game_code") @db.VarChar(120)
  name             String        @db.VarChar(180)
  category         String        @db.VarChar(80)
  status           GameStatus    @default(INACTIVE)
  isFeatured       Boolean       @default(false) @map("is_featured")
  isNew            Boolean       @default(false) @map("is_new")
  isPopular        Boolean       @default(false) @map("is_popular")
  sortOrder        Int           @default(100) @map("sort_order")
  metadata         Json?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  provider         GameProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  media            GameMedia[]
  sessions         GameSession[]

  @@unique([providerId, providerGameCode])
  @@index([providerId])
  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([isNew])
  @@index([isPopular])
  @@map("games")
}

model GameMedia {
  id         String          @id @default(uuid()) @db.Uuid
  gameId     String?         @map("game_id") @db.Uuid
  providerId String?         @map("provider_id") @db.Uuid
  type       GameMediaType
  sourceUrl  String?         @map("source_url")
  cachedUrl  String?         @map("cached_url")
  status     GameMediaStatus @default(PENDING)
  isOverride Boolean         @default(false) @map("is_override")
  metadata   Json?
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  game       Game?           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  provider   GameProvider?   @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([providerId])
  @@index([type])
  @@index([status])
  @@map("game_media")
}

model GameSession {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @map("user_id") @db.Uuid
  providerId        String            @map("provider_id") @db.Uuid
  gameId            String            @map("game_id") @db.Uuid
  status            GameSessionStatus @default(CREATED)
  launchUrl         String?           @map("launch_url")
  providerSessionId String?           @map("provider_session_id") @db.VarChar(160)
  ipAddress         String?           @map("ip_address") @db.VarChar(64)
  userAgent         String?           @map("user_agent")
  startedAt         DateTime?         @map("started_at")
  endedAt           DateTime?         @map("ended_at")
  errorCode         String?           @map("error_code") @db.VarChar(120)
  errorMessage      String?           @map("error_message")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          GameProvider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  game              Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  transfers         GameTransfer[]

  @@index([userId, createdAt])
  @@index([providerId])
  @@index([gameId])
  @@index([status])
  @@index([providerSessionId])
  @@map("game_sessions")
}

model GameTransfer {
  id                    String             @id @default(uuid()) @db.Uuid
  userId                String             @map("user_id") @db.Uuid
  providerId            String             @map("provider_id") @db.Uuid
  sessionId             String?            @map("session_id") @db.Uuid
  type                  GameTransferType
  status                GameTransferStatus @default(PENDING)
  amount                Decimal            @db.Decimal(18, 2)
  currency              String             @default("THB") @db.VarChar(10)
  idempotencyKey        String             @unique @map("idempotency_key") @db.VarChar(180)
  providerTransactionId String?            @map("provider_transaction_id") @db.VarChar(180)
  requestPayload        Json?              @map("request_payload")
  responsePayload       Json?              @map("response_payload")
  errorCode             String?            @map("error_code") @db.VarChar(120)
  errorMessage          String?            @map("error_message")
  adminNote             String?            @map("admin_note")
  resolvedAt            DateTime?          @map("resolved_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              GameProvider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  session               GameSession?       @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([providerId])
  @@index([sessionId])
  @@index([type])
  @@index([status])
  @@index([providerTransactionId])
  @@map("game_transfers")
}

model ProviderWalletSnapshot {
  id              String                       @id @default(uuid()) @db.Uuid
  userId          String                       @map("user_id") @db.Uuid
  providerId      String                       @map("provider_id") @db.Uuid
  systemBalance   Decimal                      @map("system_balance") @db.Decimal(18, 2)
  providerBalance Decimal                      @map("provider_balance") @db.Decimal(18, 2)
  difference      Decimal                      @db.Decimal(18, 2)
  status          ProviderWalletSnapshotStatus @default(UNKNOWN)
  rawPayload      Json?                        @map("raw_payload")
  checkedAt       DateTime                     @default(now()) @map("checked_at")
  createdAt       DateTime                     @default(now()) @map("created_at")
  user            User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        GameProvider                 @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([userId, checkedAt])
  @@index([providerId])
  @@index([status])
  @@map("provider_wallet_snapshots")
}

model WebhookLog {
  id                    String           @id @default(uuid()) @db.Uuid
  providerId            String           @map("provider_id") @db.Uuid
  eventType             String           @map("event_type") @db.VarChar(120)
  status                WebhookLogStatus @default(RECEIVED)
  signatureValid        Boolean          @default(false) @map("signature_valid")
  idempotencyKey        String?          @map("idempotency_key") @db.VarChar(180)
  providerTransactionId String?          @map("provider_transaction_id") @db.VarChar(180)
  rawPayload            Json?            @map("raw_payload")
  normalizedPayload     Json?            @map("normalized_payload")
  responseStatus        Int?             @map("response_status")
  retryCount            Int              @default(0) @map("retry_count")
  errorCode             String?          @map("error_code") @db.VarChar(120)
  errorMessage          String?          @map("error_message")
  createdAt             DateTime         @default(now()) @map("created_at")
  processedAt           DateTime?        @map("processed_at")
  provider              GameProvider     @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, createdAt])
  @@index([eventType])
  @@index([status])
  @@index([idempotencyKey])
  @@index([providerTransactionId])
  @@map("webhook_logs")
}


model NotificationState {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  notificationKey String    @map("notification_key") @db.VarChar(220)
  readAt          DateTime? @map("read_at")
  archivedAt      DateTime? @map("archived_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationKey])
  @@index([userId, readAt])
  @@index([userId, archivedAt])
  @@map("notification_states")
}

model NotificationPreference {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @map("user_id") @db.Uuid
  finance    Boolean  @default(true)
  security   Boolean  @default(true)
  promotion  Boolean  @default(true)
  system     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
