{
  "name": "platform-starter",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "pnpm lint:api && pnpm lint:admin && pnpm lint:member && pnpm lint:packages",
    "lint:api": "pnpm --filter @platform/api lint",
    "lint:admin": "pnpm --filter @platform/web-admin lint",
    "lint:member": "pnpm --filter @platform/web-member lint",
    "lint:packages": "pnpm --filter './packages/**' --if-present lint",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "typecheck:api": "pnpm db:generate && pnpm --filter @platform/api typecheck",
    "typecheck:admin": "pnpm --filter @platform/web-admin typecheck",
    "typecheck:member": "pnpm --filter @platform/web-member typecheck",
    "typecheck:packages": "pnpm --filter './packages/**' --if-present typecheck",
    "typecheck": "pnpm typecheck:api && pnpm typecheck:admin && pnpm typecheck:member && pnpm typecheck:packages",
    "audit:generated-drift": "node tools/audit-generated-drift.mjs",
    "audit:migration-validation": "node tools/audit-migration-validation.mjs",
    "audit:unused-exports": "node tools/audit-unused-exports.mjs",
    "audit:shared-api-client": "node tools/audit-shared-api-client.mjs",
    "audit:shared-api-client:json": "API_CLIENT_AUDIT_JSON=1 node tools/audit-shared-api-client.mjs",
    "audit:r5-closure": "pnpm audit:shared-api-client && pnpm --filter @platform/api-client test && pnpm --filter @platform/api-client build && pnpm typecheck:admin && pnpm typecheck:member",
    "audit:r6-closure": "node tools/audit-r006-closure.mjs",
    "audit:p5-closure": "node tools/audit-p5-closure.mjs",
    "audit:p4-closure": "node tools/audit-p4-closure.mjs",
    "audit:r4-closure": "node tools/audit-r004-closure.mjs",
    "audit:architecture-inventory": "node tools/audit-architecture-inventory.mjs",
    "audit:architecture-boundaries": "node tools/audit-architecture-boundaries.mjs",
    "audit:critical-test-safety": "node tools/audit-critical-test-safety.mjs",
    "audit:mutation-dto-coverage": "node tools/audit-mutation-dto-coverage.mjs",
    "audit:critical-controller-types": "node tools/audit-critical-controller-types.mjs",
    "audit:critical-service-types": "node tools/audit-critical-service-types.mjs",
    "audit:api-response-safety": "node tools/audit-api-response-safety.mjs",
    "audit:error-code-catalog": "node tools/audit-error-code-catalog.mjs",
    "audit:critical-error-contracts": "node tools/audit-critical-error-contracts.mjs",
    "audit:admin-permissions": "node tools/audit-admin-permissions.mjs",
    "audit:finance-workflows": "node tools/audit-finance-workflows.mjs",
    "audit:admin-token-storage": "node tools/audit-admin-token-storage.mjs",
    "audit:admin-xss": "node tools/audit-admin-xss-boundary.mjs",
    "test:proxy-rate-limit": "node tools/test-reverse-proxy-rate-limit.mjs",
    "verify:p1:production": "bash scripts/verify-p1-production.sh",
    "verify:p2": "bash scripts/verify-p2-product.sh",
    "verify:p3": "bash scripts/verify-p3-provider-readiness.sh",
    "test:kyc:deployed": "node tools/test-deployed-kyc.mjs",
    "test:e2e:kyc": "playwright test -c playwright.kyc.config.ts",
    "test:e2e:cms-content": "playwright test -c playwright.cms-content.config.ts",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:access": "tsx prisma/seed-access.ts",
    "db:seed:games": "tsx prisma/seed-games.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "build:api": "pnpm db:generate && pnpm --filter @platform/api build",
    "start:api": "pnpm db:generate && pnpm --filter @platform/api start:prod",
    "build:web-member": "pnpm --filter @platform/web-member build",
    "start:web-member": "pnpm --filter @platform/web-member start",
    "build:web-admin": "pnpm --filter @platform/web-admin build",
    "start:web-admin": "pnpm --filter @platform/web-admin start",
    "test:e2e:smoke": "playwright test -c playwright.smoke.config.ts",
    "test:e2e:smoke:strict": "bash scripts/require-prod-smoke-env.sh && playwright test -c playwright.smoke.config.ts",
    "test:e2e:visual": "playwright test -c playwright.visual.config.ts",
    "test:e2e:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "audit:admin-ui-permissions": "node tools/audit-admin-ui-permissions.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "1.61.1",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "prisma": "6.14.0",
    "tsx": "4.23.0",
    "turbo": "2.10.4",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.0.0"
  },
  "pnpm": {
    "overrides": {
      "prisma": "6.14.0",
      "@prisma/client": "6.14.0",
      "next": "14.2.35",
      "react": "18.2.0",
      "react-dom": "18.2.0"
    }
  }
}
