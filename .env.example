NODE_ENV=development
PORT=4000
API_PORT=4000
MEMBER_WEB_URL=http://localhost:3000
ADMIN_WEB_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000

# Keep false in production. Set true only for local/CI simulator tests.
ENABLE_PROVIDER_SIMULATOR=false

# Provider callbacks are protected by a per-IP minute bucket. Increase only for verified provider burst limits.
RATE_LIMIT_PROVIDER_WEBHOOK_PER_MINUTE=120

DATABASE_URL=postgresql://platform:platform@localhost:5432/platform?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=local_minio_user
MINIO_SECRET_KEY=set_in_local_env
MINIO_BUCKET=media

JWT_ACCESS_KEY=set_in_local_env
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

ADMIN_JWT_ACCESS_TTL=10m
ADMIN_REFRESH_TTL_HOURS=12
ADMIN_OTP_FOR_DEV=000000
ADMIN_OTP_ISSUER=Platform Admin
DEFAULT_ADMIN_SECRET=set_in_local_env
